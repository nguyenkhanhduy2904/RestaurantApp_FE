<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"

    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="10dp">

    <TextView
        android:id="@+id/tvQuantity"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="2x"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvProductName"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="1"/>

    <TextView
        android:id="@+id/tvProductName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Product 1"
        app:layout_constraintStart_toEndOf="@id/tvQuantity"
        app:layout_constraintEnd_toStartOf="@id/tvUnitPrice"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="2"/>

    <TextView
        android:id="@+id/tvUnitPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="100.000d"
        app:layout_constraintStart_toEndOf="@id/tvProductName"
        app:layout_constraintEnd_toStartOf="@id/tvFinalPrice"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="1.5"
        android:gravity="end"/>
    <TextView
        android:id="@+id/tvFinalPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="100.000d"
        app:layout_constraintStart_toEndOf="@id/tvUnitPrice"
        app:layout_constraintEnd_toStartOf="@id/tvDiscountPercent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="1.5"
        android:gravity="end"/>

    <TextView
        android:id="@+id/tvDiscountPercent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="-30%"
        android:gravity="end"
        app:layout_constraintStart_toEndOf="@id/tvFinalPrice"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="1"/>
    <TextView
        app:layout_constraintStart_toEndOf="@id/tvQuantity"
        android:id="@+id/tvNote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/tvProductName"
        android:text="this is a note"
        android:layout_marginTop="10dp"
        android:textStyle="italic"/>
</androidx.constraintlayout.widget.ConstraintLayout>