<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp">

        <!-- Food Image with rounded corners -->
        <ImageView
            android:id="@+id/ivFoodImage"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/default_food_img"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_food_image"
            android:clipToOutline="true"
            android:layout_gravity="center_vertical" />

        <!-- Text Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_gravity="center_vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/txtFoodName"
                    android:layout_width="0dp"
                    android:layout_weight="8"
                    android:layout_height="wrap_content"
                    android:text="Grilled Salmon"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:letterSpacing="0.01" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDelete"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/ic_trash_foreground"
                    android:textSize="20sp"
                    android:textColor="@color/white"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#E8472A"
                    app:cornerRadius="17dp"
                    android:contentDescription="Add to cart" />

            </LinearLayout>



            <!-- Optional description label -->


            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp" />

            <!-- Price + Button row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1.5"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/txtFoodPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="20.000đ"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:padding="5dp"/>
                    <TextView
                        android:id="@+id/txtPriceReduction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-20%"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/green"
                        android:background="@drawable/bg_price_reduction"

                        android:padding="5dp"
                        android:layout_gravity="center"/>
                    <LinearLayout
                        android:layout_marginStart="20dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <com.google.android.material.button.MaterialButton
                            android:layout_marginEnd="10dp"
                            android:id="@+id/btnDecrease"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:textSize="20sp"
                            android:textColor="@color/white"
                            android:text="-"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="#E8472A"
                            app:cornerRadius="17dp"/>

                        <EditText
                            android:id="@+id/etQuantity"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="bottom"
                            android:text="2"
                            android:textSize="14dp"
                            android:inputType="number"
                            android:background="@null"

                            />

                        <com.google.android.material.button.MaterialButton
                            android:layout_marginStart="10dp"
                            android:id="@+id/btnIncrease"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:textSize="20sp"
                            android:textColor="@color/white"
                            android:text="+"
                            android:padding="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="#E8472A"
                            app:cornerRadius="17dp"/>

                    </LinearLayout>

                </LinearLayout>





                <!-- Add to cart button -->


            </LinearLayout>

            <EditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fresh Healthy"
                android:textSize="20sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>



</androidx.cardview.widget.CardView>